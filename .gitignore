# ==========================================
# SW2LLM-Parser .gitignore
# v6.0 Super Pipeline / .NET 10 + SolidWorks
# ==========================================

# ── 1. C# 编译产物 & NuGet 还原 ──
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
publish/
*.nupkg
*.snupkg

# ── 2. Visual Studio 本地工作区 ──
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.slnx
*.DotSettings.user

# ── 3. SolidWorks 运行时临时锁文件 ──
~$*.sldprt
~$*.sldasm
~$*.slddrw
*.tmp
AppID.tmp

# ── 4. 🔒 核心安全：拦截所有本地生成的数据集 JSON ──
#     v6.0 流式管道输出 STREAM_DATASET_*.json，防止泄露企业零件参数
*.json
STREAM_DATASET_*
MASTER_DATASET_*

# ── 5. .NET 全局工具本地清单 ──
dotnet-tools.json
